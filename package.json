{
  "name": "kobo-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing KoboToolbox/ODK survey data (forms, submissions, summaries) to AI agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "kobo-mcp-server": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "node --import tsx --test src/**/*.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kobotoolbox",
    "odk",
    "survey"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
