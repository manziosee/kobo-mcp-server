{
  "name": "kobo-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing KoboToolbox survey data (forms, submissions, media, geodata, QA checks) to AI agents",
  "mcpName": "io.github.manziosee/kobo-mcp-server",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "kobo-mcp-server": "./build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manziosee/MCP.git"
  },
  "homepage": "https://github.com/manziosee/MCP#readme",
  "bugs": {
    "url": "https://github.com/manziosee/MCP/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('build/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kobotoolbox",
    "odk",
    "survey"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
