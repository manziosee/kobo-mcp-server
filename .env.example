# KoboToolbox API token (Account Settings -> Security -> API Token)
KOBO_API_TOKEN=

# Base URL of your Kobo server API. Use https://kf.kobotoolbox.org for the
# hosted global server, https://eu.kobotoolbox.org for the EU server, or your
# self-hosted kpi URL. No trailing slash.
KOBO_BASE_URL=https://kf.kobotoolbox.org

# Optional, comma-separated field names (bare or full "group/field" path) to
# permanently replace with "[REDACTED]" in every tool's output, regardless of
# what's asked - e.g. names, phone numbers, national IDs. Enforced centrally
# in the API client, not per-tool. See README > Data protection.
KOBO_REDACT_FIELDS=
